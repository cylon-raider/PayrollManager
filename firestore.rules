rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // User profiles
    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Staff Data
    match /staff/{staffId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Schedule Data
    match /schedule/{dayId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Daily Logs (Hours, Collections)
    match /daily_logs/{logId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Notes per user + page
    match /users/{userId}/pages/{pageId}/notes/{noteId} {
      allow read, create: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow update, delete: if signedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
